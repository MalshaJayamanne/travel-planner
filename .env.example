# ─────────────────────────────────────────────
#  Horizon Travel Planner — Environment Variables
#  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Database (Supabase / PostgreSQL) ──────────
# Pooled connection for runtime queries
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection for Prisma migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── Authentication (NextAuth) ─────────────────
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
# In production replace with your Vercel domain:
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret"

# ── AI — Google Gemini ────────────────────────
GEMINI_API_KEY=""

# ── Weather API ───────────────────────────────
OPENWEATHER_API_KEY=""

# ── Cloudinary (Photo Gallery / Media Upload) ─
# Create a free account at https://cloudinary.com
# Leave blank to use local /public/uploads fallback
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
