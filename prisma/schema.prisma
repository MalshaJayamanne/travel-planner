generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String?
  name         String?
  createdAt    DateTime     @default(now())
  trips        Trip[]
  preferences  Preference[]
}

model Trip {
  id          String      @id @default(cuid())
  userId      String
  destination String
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id])
  itineraries Itinerary[]
}

model Itinerary {
  id         String @id @default(cuid())
  tripId     String
  day        Int
  activities String
  trip       Trip   @relation(fields: [tripId], references: [id])
}

model Preference {
  id          String @id @default(cuid())
  userId      String
  interests   String
  travelStyle String
  user        User   @relation(fields: [userId], references: [id])
}
