generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  name         String?
  email        String       @unique
  passwordHash String
  image        String?
  createdAt    DateTime     @default(now())
  role         String       @default("TRAVELER")
  isActive     Boolean      @default(true)

  trips        Trip[]
  expenses     Expense[]
  preferences  Preference[]
  wishlists    Wishlist[]
  photos       Photo[]
  stories      Story[]
}

model Wishlist {
  id          String   @id @default(cuid())
  userId      String
  title       String
  destination String
  notes       String
  priority    String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id            String      @id @default(cuid())
  title         String
  startLocation String      @default("")
  country       String      @default("Sri Lanka")
  city          String      @default("")
  destination   String
  startDate     DateTime
  endDate       DateTime
  budget        Float
  userId        String
  createdAt     DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  itineraries Itinerary[]
  photos      Photo[]
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  subcategory String?
  date        DateTime @default(now())
  description String?
  tripId      String
  userId      String

  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Itinerary {
  id            String              @id @default(cuid())
  tripId        String
  day           Int
  activities    String
  activityItems ItineraryActivity[]

  trip          Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model ItineraryActivity {
  id                  String    @id @default(cuid())
  itineraryId         String
  title               String
  timeOfDay           String    // Morning, Afternoon, Evening
  status              String    @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED
  order               Int       @default(0)
  travelTime          String?   @default("")
  suggestedAttraction String?   @default("")
  restaurant          String?   @default("")
  accommodation       String?   @default("")
  notes               String?   @default("")
  locked              Boolean   @default(false)

  itinerary           Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
}

model Preference {
  id          String @id @default(cuid())
  userId      String
  interests   String
  travelStyle String

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Photo {
  id        String   @id @default(cuid())
  userId    String
  url       String
  publicId  String?
  caption   String?
  location  String?
  tripId    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
}

model Story {
  id         String       @id @default(cuid())
  userId     String
  title      String
  content    String       @db.Text
  location   String?
  coverUrl   String?
  date       DateTime     @default(now())
  status     String       @default("PENDING") // PENDING, APPROVED, REJECTED
  visibility String       @default("PUBLIC") // PUBLIC, PRIVATE
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    StoryImage[]
}

model StoryImage {
  id        String   @id @default(cuid())
  storyId   String
  url       String
  publicId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Destination {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  image       String   @default("")
  category    String   // e.g. Adventure, Beach, Historical, Nature, Cultural
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Feedback {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  category  String   @default("FEEDBACK") // FEEDBACK, SUPPORT, CONTACT
  status    String   @default("NEW")      // NEW, IN_PROGRESS, RESOLVED
  createdAt DateTime @default(now())
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // INFO, WARN, ERROR
  message   String   @db.Text
  category  String   // API, DATABASE, AI, AUTH
  timestamp DateTime @default(now())
}

model Guide {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  content   String   @db.Text
  category  String   @default("General")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


